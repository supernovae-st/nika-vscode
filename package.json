    "configuration": {
      "title": "Nika",
      "properties": {
        "nika.server.path": {
          "type": "string",
          "default": "nika",
          "description": "Path to the nika binary. Uses PATH by default."
        },
        "nika.server.autoDownload": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download the nika binary from GitHub releases if not found in PATH."
        },
        "nika.server.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments passed to the nika lsp command."
        },
        "nika.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay hints (timeout annotations, model costs, binding labels)."
        },
        "nika.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show code lens actions (Run, Validate, task count, last run status)."
        },
        "nika.nudge.firstCleanCheck": {
          "type": "boolean",
          "default": true,
          "description": "Once per workspace, when a workflow first checks clean, suggest the next step (run it — mock/echo needs no key)."
        },
        "nika.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Nika language server."
        },
        "nika.intel.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Client-side template intelligence inside ${{ ... }} islands (completions, hover, go-to-definition for tasks/with/env/secrets/vars refs)."
        },
        "nika.diagnostics.runOn": {
          "type": "string",
          "enum": [
            "type",
            "save",
            "off"
          ],
          "default": "type",
          "description": "When to run `nika check --json` for editor diagnostics (client path, used until the LSP ships). 'type' is debounced."
        },
        "nika.diagnostics.workspace": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Lint CLOSED `*.nika.yaml` files across the workspace (`nika check --json`) so every workflow shows in the Problems panel. Capped at 300 files per sweep (logged when hit); open files stay with the live controller."
        },
        "nika.diagnostics.severity": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ]
          },
          "default": {},
          "markdownDescription": "Remap finding severity per code — exact (`NIKA-DAG-003`), glob family (`NIKA-SEC-*`), or client lints (`nika.literal-secret` · `nika.redundant-dep` · `nika.unused-schema`). Exact keys win over globs; `off` hides the squiggle (quick fixes stay available)."
        },
        "nika.secretsLint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Warn on literal credentials pasted in workflow YAML (pure local scan) with a ${{ env.VAR }} quick fix."
        },
        "nika.traces.keep": {
          "type": "number",
          "default": 200,
          "description": "Journal housekeeping: keep the newest N run journals per workflow directory (0 = unlimited). The newest always survive."
        },
        "nika.traces.glob": {
          "type": "string",
          "default": "**/.nika/traces/*.ndjson",
          "description": "Where the Runs view looks for flight-recorder traces."
        },
        "nika.traces.live": {
          "type": "boolean",
          "default": true,
          "description": "Live-overlay a growing trace onto the open DAG panel while an engine writes a run (statuses update in real time)."
        },
        "nika.run.liveDag": {
          "type": "boolean",
          "default": true,
          "description": "Run workflows by streaming `nika run --json` into the DAG panel live (statuses paint in real time). Off = run in a terminal for raw output."
        },
        "nika.replay.speed": {
          "type": "number",
          "default": 6,
          "description": "Trace replay time compression in the DAG webview (6 = 6× faster than recorded, engine default)."
        },
        "nika.dag.theme": {
          "type": "string",
          "enum": [
            "nika",
            "editor",
            "phosphor",
            "auto"
          ],
          "enumDescriptions": [
            "The Nika design language — warm engineered-black canvas, one blue accent, verb-hue tiles, Martian Mono (the brand skin, pinned dark)",
            "Adaptive — derives every surface AND the accent from your editor theme (--vscode-* variables, focusBorder as accent)",
            "Phosphor — true-black OLED register, phosphor-green ink, hairlines; verb chroma sleeps at rest and wakes only on LIVE tasks (explicit choice — auto never picks it)",
            "Auto — the brand skin on dark themes, the adaptive skin on light themes"
          ],
          "default": "nika",
          "description": "Visual skin of the DAG panel. High-contrast themes and forced colors always win over every skin."
        },
        "nika.dag.followActiveEditor": {
          "type": "boolean",
          "default": true,
          "description": "The open DAG panel re-targets when you switch to another .nika.yaml (debounced)."
        },
        "nika.editor.xray": {
          "type": "boolean",
          "default": true,
          "description": "Ghost values: inlay hints show what each ${{ tasks.x… }} ref resolved to in the last matching recorded run."
        },
        "nika.editor.runHighlight": {
          "type": "boolean",
          "default": true,
          "description": "Light the YAML spans of RUNNING tasks while a run or replay is at them — the source is the timeline."
        },
        "nika.dag.cursorSync": {
          "type": "boolean",
          "default": true,
          "description": "Soft halo in the DAG on the task your editor caret is in (same workflow · panel visible)."
        },
        "nika.decorations.verbDots": {
          "type": "boolean",
          "default": true,
          "description": "Verb-tinted gutter dots on each task line — the nika.sh verb canon (infer blue · exec orange · invoke cyan · agent violet)."
        },
        "nika.editor.runDecorations": {
          "type": "boolean",
          "default": true,
          "description": "End-of-line run badges per task after a run (✓ duration · cost — failed in red): the run lives in the editor."
        },
        "nika.ai.toolsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Register the Nika Language Model Tools (check · explain · graph · workspace on 0.99+ binaries) so in-editor AI agents validate workflows through the real oracle."
        },
        "nika.autoSetup": {
          "type": "boolean",
          "default": true,
          "description": "On first activation with the binary present, wire MCP for this host automatically (nika wire is idempotent). Turn off for manual setup via 'Nika: Setup MCP'."
        },
        "nika.explorerBadge": {
          "type": "boolean",
          "default": true,
          "description": "Show the 🦋 badge on *.nika.yaml files in the Explorer (icon themes own the file icon slot; the badge adds nika identity without replacing your theme)."
        }
      }
    },
    "configurationDefaults": {
      "[nika]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced"
      },
      "files.associations": {
        "*.nika.yaml": "nika",
        "*.nika.yml": "nika"
      }
    },
    "menus": {
      "webview/context": [
        {
          "command": "nika.canvas.runTask",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "1_run@1"
        },
        {
          "command": "nika.canvas.openYaml",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "1_run@2"
        },
        {
          "command": "nika.canvas.focusTask",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "1_run@3"
        },
        {
          "command": "nika.canvas.renameTask",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "2_edit@1"
        },
        {
          "command": "nika.canvas.duplicateTask",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "2_edit@2"
        },
        {
          "command": "nika.canvas.deleteTask",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "2_edit@3"
        },
        {
          "command": "nika.canvas.copyTaskId",
          "when": "webviewId == 'nika.dagView' && webviewSection == 'nikaTask'",
          "group": "9_copy@1"
        }
      ],
      "commandPalette": [
        {
          "command": "nika.typeOutput",
