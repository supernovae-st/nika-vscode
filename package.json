  "scripts": {
    "vscode:prepublish": "npm run clean && npm run compile",
    "clean": "rm -rf out",
    "compile": "npm run typecheck && node esbuild.mjs",
    "typecheck": "tsc -p ./ && tsc --noEmit --strict --target es2020 --module es2022 --moduleResolution bundler --lib es2022,dom,dom.iterable src/webview/dag.ts",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src",
    "parity": "node scripts/parity.mjs",
    "test": "vitest run && node scripts/parity.mjs && node scripts/tokens-parity.mjs && npm run lint",
    "test:watch": "vitest",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "test:integration": "npm run compile && npm run compile:integration && node out-integration/runTests.js",
    "package": "vsce package"
  },
