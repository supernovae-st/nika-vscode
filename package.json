{
  "name": "nika-lang",
  "displayName": "Nika Workflow Language",
  "description": "Intent as Code — Nika, the workflow language for AI (.nika.yaml). A content-first DAG canvas that runs, replays and AUDITS your workflow before a token is spent (cost ceiling · secret-flow · permits), check-as-you-type diagnostics, schema-derived completions, agent tools. For VS Code, Cursor, Windsurf, VSCodium.",
  "version": "0.102.0",
  "publisher": "supernovae",
  "license": "AGPL-3.0-or-later",
  "icon": "icons/nika-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/supernovae-st/nika-vscode"
  },
  "homepage": "https://nika.sh",
  "bugs": {
    "url": "https://github.com/supernovae-st/nika-vscode/issues"
  },
  "galleryBanner": {
    "color": "#08090b",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Visualization",
    "AI",
    "Machine Learning"
  ],
  "keywords": [
    "nika",
    "yaml",
    "workflow",
    "ai",
    "llm",
    "mcp",
    "cursor",
    "windsurf",
    "agent",
    "lsp",
    "dag",
    "canvas",
    "pipeline",
    "orchestration",
    "replay",
    "audit",
    "automation",
    "linter"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:nika",
    "workspaceContains:**/*.nika.yaml"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In Restricted Mode the workspace cannot override which binary the extension executes; static language features stay on.",
      "restrictedConfigurations": [
        "nika.server.path",
        "nika.server.extraArgs"
      ]
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Diagnostics, graph and runs need a real file system and the nika binary; syntax, snippets and expression intel work everywhere."
    }
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nika",
          "title": "Nika",
          "icon": "./icons/nika-dark.svg"
        }
      ]
    },
    "views": {
      "nika": [
        {
          "id": "nikaWorkflows",
          "name": "Workflows"
        },
        {
          "id": "nikaRuns",
          "name": "Runs (flight recorder)"
        }
      ]
    },
    "languages": [
      {
        "id": "nika",
        "aliases": [
          "Nika Workflow",
          "nika"
        ],
        "extensions": [
          ".nika.yaml"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/nika-light.svg",
          "dark": "./icons/nika-dark.svg"
        },
        "filenamePatterns": [
          "*.nika.yaml",
          "*.nika.yml"
        ]
      }
    ],
    "grammars": [
      {
        "language": "nika",
        "scopeName": "source.nika",
        "path": "./syntaxes/nika.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "nika",
        "scopes": {
          "keyword": [
            "keyword.control.nika"
          ],
          "macro": [
            "entity.name.function.verb.nika"
          ],
          "property": [
            "variable.other.property.nika"
          ],
          "variable": [
            "variable.other.template.nika"
          ],
          "function": [
            "entity.name.function.nika"
          ],
          "type": [
            "entity.name.type.nika"
          ],
          "comment": [
            "comment.nika"
          ]
        }
      }
    ],
