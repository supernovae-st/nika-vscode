    "languageModelTools": [
      {
        "name": "nika_check",
        "displayName": "Nika Check",
        "toolReferenceName": "nikaCheck",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Statically validate a Nika workflow (.nika.yaml) BEFORE running it. Returns the full machine-readable pre-flight report: conformance violations, secret leaks/egresses, permits (capability) escapes with machine-applicable fixes, schema findings, unknown tools, cost ceiling. You MUST call this after EVERY create or edit of a .nika.yaml file, and fix every finding before declaring the task done — never report success while findings remain. Not for generic YAML or GitHub Actions files.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "Absolute path to the .nika.yaml file (defaults to the active editor)."
            }
          }
        }
      },
      {
        "name": "nika_explain",
        "displayName": "Nika Explain",
        "toolReferenceName": "nikaExplain",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Explain a NIKA-XXXX error code: cause, category, and the fix form. Use when a check report or diagnostic carries a code you do not recognize.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "The error code, e.g. NIKA-440 (bare 440 also accepted)."
            }
          },
          "required": [
            "code"
          ]
        }
      },
      {
        "name": "nika_graph",
        "displayName": "Nika Graph",
        "toolReferenceName": "nikaGraph",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Project the canonical execution DAG of a Nika workflow (graph_format 1 JSON): topologically sorted task nodes with verb, model, when-gates, fan-out and static cost intervals, plus depends_on edges. Requires the workflow to pass conformance first.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "Absolute path to the .nika.yaml file (defaults to the active editor)."
            }
          }
        }
      },
      {
        "name": "nika_workspace",
        "displayName": "Nika Workspace",
        "toolReferenceName": "nikaWorkspace",
        "canBeReferencedInPrompt": true,
        "modelDescription": "The whole Nika workspace truth in ONE call (context_version 1 JSON): every *.nika.yaml audited (clean/strict verdicts, findings count, tasks, waves, per-verb breakdown, cost ceiling with FLOOR honesty, permits), the most recent recorded runs folded from the flight recorder (verdict, spend, unpriced calls), environment facts (wired clients, local providers, cloud key COUNTS — never values), and cross-file rollups. Arrays are capped and counted. Call this FIRST to orient before reading or editing workflows. Requires a nika binary with the context verb (0.99+); on older binaries this tool is not registered.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "nika",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "The nika subcommand to run (check · run · inspect)"
          },
          "file": {
            "type": "string",
            "description": "Workflow file (defaults to active editor)"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "nika",
        "owner": "nika",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*\\.nika\\.ya?ml):(\\d+):(\\d+):\\s+(error|warning)\\[(NIKA-\\d+)\\]:\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    ],
    "walkthroughs": [
      {
        "id": "nika.gettingStarted",
        "title": "Get started with Nika",
        "description": "From zero to a proven, replayable AI workflow.",
        "steps": [
          {
            "id": "install",
            "title": "Install the nika engine",
            "description": "The extension drives the `nika` binary (LSP · check · run · DAG).\n[⚡ Finish Setup — one gesture](command:nika.finishSetup)\nVerified download · MCP wired · LSP on. Prefer brew? `brew install supernovae-st/tap/nika` — then the same button detects it.",
            "media": {
              "markdown": "walkthrough/01-install.md"
            },
            "completionEvents": [
              "onCommand:nika.checkBinary",
              "onCommand:nika.finishSetup"
            ]
          },
          {
            "id": "create",
            "title": "Create your first workflow",
            "description": "Scaffold a `.nika.yaml` with the canonical envelope.\n[New Workflow](command:nika.newWorkflow)",
            "media": {
              "markdown": "walkthrough/02-create.md"
            },
            "completionEvents": [
              "onCommand:nika.newWorkflow",
              "onCommand:nika.initProject"
            ]
          },
          {
            "id": "validate",
            "title": "Validate as you type",
            "description": "Diagnostics · completions · hover docs are live via the LSP. Run an explicit check ·\n[Validate Workflow](command:nika.checkWorkflow)",
            "media": {
              "markdown": "walkthrough/03-validate.md"
            },
            "completionEvents": [
              "onCommand:nika.checkWorkflow"
            ]
          },
          {
            "id": "run",
            "title": "Run it (no API key needed)",
            "description": "The starter uses `model: mock/echo` — deterministic · zero keys.\n[Run Workflow](command:nika.runWorkflow)",
            "media": {
              "markdown": "walkthrough/04-run.md"
            },
            "completionEvents": [
              "onCommand:nika.runWorkflow"
            ]
          },
          {
            "id": "dag",
            "title": "See the DAG",
            "description": "Visualize task dependencies · click a node to jump to its YAML.\n[Show DAG](command:nika.showDag)",
            "media": {
              "markdown": "walkthrough/05-dag.md"
            },
            "completionEvents": [
              "onCommand:nika.showDag"
            ]
          },
          {
            "id": "timetravel",
            "title": "Time-travel a recorded run (F5)",
            "description": "Set a breakpoint on any task line and press **F5** — the engine replays your latest recorded run under the debugger: step forward AND backward through settles, outputs in the Variables pane. Replay never re-executes.\n[Debug the latest run](command:workbench.action.debug.start)",
            "media": {
              "markdown": "walkthrough/08-timetravel.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.debug.start"
            ]
          },
          {
            "id": "proof",
            "title": "Prove it ran (chain · reproduce · export)",
            "description": "Every run hash-chains its journal — the Runs view shows a shield when a journal fails verification, and the run report states its own integrity. Right-click a run → **Reproduce Run** classifies WHY two runs diverge (NONDETERMINISTIC names the flaky task). **Export to OpenTelemetry** ships the trace — with its chain head — to Jaeger/Grafana/Langfuse.\n[Open the Runs view](command:nikaRuns.focus)",
            "media": {
              "markdown": "walkthrough/07-proof.md"
            },
            "completionEvents": [
              "onCommand:nika.reproduceRun",
              "onCommand:nika.exportOtel",
              "onCommand:nika.verifyTrace"
            ]
          },
          {
            "id": "agents",
            "title": "Make your AI an expert",
            "description": "`nika init` writes schema wiring, AGENTS.md, and Cursor rules; this command wires MCP so agents can check workflows and explain failures through the real oracle.\n[Setup agents](command:nika.setupMcp)",
            "media": {
              "markdown": "walkthrough/06-agents.md"
            },
            "completionEvents": [
              "onCommand:nika.setupMcp",
              "onCommand:nika.initProject"
            ]
          },
          {
            "id": "community",
            "title": "Keep it findable",
            "description": "Nika is independent open source — a star is how the next person finds it.\n[Star on GitHub](https://github.com/supernovae-st/nika)",
            "media": {
              "markdown": "walkthrough/09-community.md"
            },
            "completionEvents": [
              "onLink:https://github.com/supernovae-st/nika"
            ]
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "nikaWorkflows",
        "when": "nika.journey == 'noBinary'",
        "contents": "Nika turns repeatable AI work into files: one `.nika.yaml`, four verbs, audited before it runs.\n[⚡ Finish setup — install engine + wire everything](command:nika.finishSetup)\nVerified download (SHA256SUMS) · MCP · LSP — one gesture, everything lights up."
      },
      {
        "view": "nikaWorkflows",
        "when": "nika.journey == 'unequipped'",
        "contents": "This repo is not equipped for Nika yet.\n[🚀 Init this project — scaffold + wire everything](command:nika.initProject)\nAgent rules · MCP · schema wiring — one gesture, skip-if-exists.\n[💬 New session — wizard · describe · templates](command:nika.newSession)\n[▶ Run the 10-second proof](command:nika.runProof)"
      },
      {
        "view": "nikaWorkflows",
        "when": "nika.journey != 'noBinary' && nika.journey != 'unequipped'",
        "contents": "Nika turns repeatable AI work into files: one `.nika.yaml`, four verbs, audited before it runs.\n[💬 New session — wizard · describe · templates](command:nika.newSession)\n[🚀 Init project — scaffold + wire everything](command:nika.initProject)\n[＋ New workflow](command:nika.newWorkflow)\n[✨ Describe → generate](command:nika.generateWorkflow)\n[▤ Browse embedded examples](command:nika.browseExamples)\n[◇ Open the canvas](command:nika.showDag)\nEverything else lives under ⇧⌘P → “Nika”, or [open the menu](command:nika.showMenu)."
      },
      {
        "view": "nikaRuns",
        "contents": "No recorded runs yet — every run writes a tamper-evident, hash-chained trace here.\n[▶ Run a workflow](command:nika.runWorkflow)\nMock needs no key: run with `mock/echo` for an offline, zero-spend rehearsal.\n[▤ Try an embedded example](command:nika.browseExamples)"
      }
    ],
    "breakpoints": [
      {
        "language": "nika"
      }
    ],
    "debuggers": [
      {
        "type": "nika",
        "label": "Nika Replay",
        "languages": [
          "nika"
        ],
        "configurationAttributes": {
          "launch": {
            "type": "object",
            "required": [
              "workflow",
              "replay"
            ],
            "properties": {
              "workflow": {
                "type": "string",
                "description": "The .nika.yaml the run executed (stack frames point here)."
              },
              "replay": {
                "type": "string",
                "description": "A recorded run journal (.nika/traces/*.ndjson) — replay never re-executes."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "nika",
            "request": "launch",
            "name": "Replay latest run",
            "workflow": "${file}",
            "replay": ""
          }
        ],
        "configurationSnippets": [
          {
            "label": "Nika: Replay a recorded run",
            "description": "Time-travel debug over a .nika/traces journal (stepBack included).",
            "body": {
              "type": "nika",
              "request": "launch",
              "name": "Replay ${1:run}",
              "workflow": "^\"\\${workspaceFolder}/${2:workflow.nika.yaml}\"",
              "replay": "^\"\\${workspaceFolder}/${3:.nika/traces/run.ndjson}\""
            }
          }
        ]
      }
    ]
